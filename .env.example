# FarmersQuest web, example environment configuration.
# Copy to .env.local and fill in real values for your environment. Never commit a real .env file.
# Only variables prefixed with VITE_ are exposed to the client bundle, so never put a secret here:
# everything in this file ships to the browser. Secrets live in the API, never in the web client.

# ----- API -----
# Base URL of the FarmersQuest API this client talks to. No trailing slash.
# Local API default (see ../farmersquest-api): http://localhost:5099
VITE_API_BASE_URL=http://localhost:5099

# ----- App -----
# Display name used in the shell and document title.
VITE_APP_NAME=FarmersQuest
# Environment label shown in non-production builds (Development, Staging, Production).
VITE_APP_ENVIRONMENT=Development
# Public support/contact email shown in the footer and legal pages. Not a secret.
VITE_SUPPORT_EMAIL=support@farmersquest.ng
